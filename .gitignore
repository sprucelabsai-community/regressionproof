# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.*
.env-*
!.env.example

# macOS files
.DS_Store

# Rejected "git apply" patch files
*.rej

build/
esm/

tmp/

# Package-specific env files (allow .env.example in packages)
packages/**/.env
packages/**/.env.*
packages/**/.env-*
!packages/**/.env.example

yarn.lock
package-lock.json

**/.spruce/*cache.json

# Training artifacts too large for git remote limits
training/data/staging/snapshot_examples.ndjson
training/data/staging/micro_step_examples.ndjson
training/data/normalized/round1.sft.jsonl
training/data/splits/train.jsonl
training/models/

# Local training virtualenvs and transient validation artifacts
training/.venv*/
training/reports/.tmp_*
