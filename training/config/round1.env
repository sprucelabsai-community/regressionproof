export ROUND1_LOG_STEPS=10
export ROUND1_SAVE_STEPS=100
export ROUND1_EVAL_STEPS=100
export ROUND1_MAX_PATCH_CHARS=16000
export ROUND1_MAX_DOC_CHARS=12000
